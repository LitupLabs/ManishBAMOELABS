  <decision name="LoanDecision" id="_28656BAE-DB8E-4461-9813-B4CCFFBA03B2">
    <variable id="_4586A532-D142-4348-9259-EE7FAC577FEB" typeRef="boolean" name="LoanDecision" />
    <informationRequirement id="_FD8B7E65-E38D-4040-BAAF-CD0BD2EA73D5">
      <requiredInput href="#_C849338E-2A36-4A19-A067-2538237DFBE7" />
    </informationRequirement>
    <literalExpression id="_587CA8F7-9295-4887-BDFA-680E3D19F395" typeRef="boolean" label="LoanDecision">
      <text>LoanApplication.customer.creditScore &gt; 650
and LoanApplication.financials.monthlyIncome &gt; 30000</text>
    </literalExpression>
  </decision>
  <decision name="Risk Category" id="_D58A6CD2-48DE-49C5-911D-1747EA95D394">
    <variable name="Risk Category" id="_675CF564-E0B0-476C-B69A-A1D08F8040A9" typeRef="string" />
    <informationRequirement id="_28561A74-5E52-42D2-AE8B-C8074456034D">
      <requiredInput href="#_C849338E-2A36-4A19-A067-2538237DFBE7" />
    </informationRequirement>
    <literalExpression id="_C58E855B-BDB3-4992-8B54-6CDB3137109C" typeRef="string" label="Risk Category">
      <text>if LoanApplication.customer.creditScore &gt;= 750 then &quot;LOW&quot;
else if LoanApplication.customer.creditScore &gt;= 650 then &quot;MEDIUM&quot;
else &quot;HIGH&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_C88CB914-9FD6-4845-8F06-7A1C9BBECE4F">
    <variable name="Financial Eligibility" id="_EF3A6A90-5B90-4303-87E9-C6C42FC01BDB" typeRef="boolean" />
    <knowledgeRequirement id="_447C2A4B-FE8F-40C5-B375-A509729CD309">
      <requiredKnowledge href="#_42032EA2-104C-444A-A10C-8CD11B0B83DD" />
    </knowledgeRequirement>
    <literalExpression id="_9D7F1D2A-E8A8-49BB-BB08-406772F0D504" typeRef="boolean" label="Financial Eligibility">
      <text>Calculate Financial Strength &gt; 25000
</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Eligibility Score" id="_97B8AE97-E346-4CE5-94EB-1C1364C3C66A">
    <variable name="Calculate Eligibility Score" id="_118503B8-42FD-40CB-8800-7D82F18354D7" typeRef="number" />
    <encapsulatedLogic label="Calculate Eligibility Score" typeRef="number" id="_0885C9F4-D740-4229-88D5-54BAD5316950" kind="FEEL">
      <formalParameter id="_117DA1CF-7A48-41B9-B76A-6B46C3329466" name="customer" typeRef="Customer" />
      <literalExpression id="_D6B2A1FC-A431-4FEC-9B5B-DA8DB2019F9E" typeRef="number" label="Return">
        <text>if customer.creditScore &gt;= 750 then 3
else if customer.creditScore &gt;= 650 then 2
else 1</text>
      </literalExpression>
    </encapsulatedLogic>
    <authorityRequirement id="_102E569C-C13A-4FF3-BA72-1BFCDA864ED2">
      <requiredAuthority href="#_0860A2BB-F01E-4027-8284-401168CC17E7" />
    </authorityRequirement>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Strength" id="_42032EA2-104C-444A-A10C-8CD11B0B83DD">
    <variable name="Calculate Financial Strength" id="_5B2930FB-E325-4764-93A7-3287B6366CF9" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Strength" id="_D69D5E92-1534-4CA2-8EB5-4AC2888DF004" kind="FEEL" typeRef="number">
      <formalParameter id="_9DBE527F-F1D2-432D-A4D5-09FFFFA0B5EE" name="financials" typeRef="Financials" />
      <literalExpression id="_6F1C391B-103A-446C-B616-A11AE2CA9B64" label="Return">
        <text>(financials.monthlyIncome + sum(financials.otherIncomes)) </text>
      </literalExpression>
    </encapsulatedLogic>
    <authorityRequirement id="_1D407E82-7AFB-4DDB-9347-82B78FFE3B08">
      <requiredAuthority href="#_0860A2BB-F01E-4027-8284-401168CC17E7" />
    </authorityRequirement>
  </businessKnowledgeModel>
